<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <schema id="org.gnome.shell.extensions.dynamic-island"
          path="/org/gnome/shell/extensions/dynamic-island/">

    <!-- ── Position ──────────────────────────────────────────────────────── -->
    <key name="position-offset" type="i">
      <default>0</default>
      <summary>Horizontal offset from screen center (px)</summary>
    </key>

    <!-- ── Core feature toggles ──────────────────────────────────────────── -->
    <key name="show-album-art" type="b">
      <default>true</default>
      <summary>Show album art in expanded view</summary>
    </key>
    <key name="show-seek-bar" type="b">
      <default>true</default>
      <summary>Show seek bar in expanded view</summary>
    </key>
    <key name="auto-hide" type="b">
      <default>false</default>
      <summary>Auto-hide when no media is active</summary>
    </key>
    <key name="auto-hide-delay" type="i">
      <default>15</default>
      <summary>Seconds of idle before the island hides (0 = never)</summary>
      <description>
        When auto-hide is enabled, the island fades out after this many seconds
        of inactivity (no media, OSD, notification, or hover). Set to 0 to
        disable the idle timeout (island stays until media stops).
      </description>
    </key>
    <key name="intercept-osd" type="b">
      <default>true</default>
      <summary>Replace system volume/brightness OSD</summary>
    </key>
    <key name="show-notifications" type="b">
      <default>true</default>
      <summary>Show notification toasts in the island</summary>
    </key>

    <!-- ── Weather widget ───────────────────────────────────────────────── -->
    <key name="show-weather" type="b">
      <default>false</default>
      <summary>Show weather in the idle pill</summary>
      <description>Display current temperature and condition alongside the clock.</description>
    </key>
    <key name="weather-location" type="s">
      <default>''</default>
      <summary>Weather location (empty = auto-detect)</summary>
      <description>City name or leave empty to detect automatically from your IP address.</description>
    </key>
    <key name="weather-units" type="s">
      <default>'metric'</default>
      <summary>Temperature units: "metric" (°C) or "imperial" (°F)</summary>
    </key>

    <!-- ── Bluetooth indicator ───────────────────────────────────────────── -->
    <key name="show-bluetooth" type="b">
      <default>true</default>
      <summary>Show Bluetooth indicator in the idle pill</summary>
      <description>When a Bluetooth device is connected, show its icon and battery in the pill.</description>
    </key>

    <!-- ── Scrobbling — Last.fm ───────────────────────────────────────────── -->
    <key name="lastfm-enabled" type="b">
      <default>false</default>
      <summary>Enable Last.fm scrobbling</summary>
    </key>
    <key name="lastfm-api-key" type="s">
      <default>''</default>
      <summary>Last.fm API key</summary>
    </key>
    <key name="lastfm-api-secret" type="s">
      <default>''</default>
      <summary>Last.fm API secret</summary>
    </key>
    <key name="lastfm-session-key" type="s">
      <default>''</default>
      <summary>Last.fm session key (stored after authentication)</summary>
    </key>
    <key name="lastfm-username" type="s">
      <default>''</default>
      <summary>Last.fm username</summary>
    </key>

    <!-- ── Scrobbling — ListenBrainz ─────────────────────────────────────── -->
    <key name="listenbrainz-enabled" type="b">
      <default>false</default>
      <summary>Enable ListenBrainz scrobbling</summary>
    </key>
    <key name="listenbrainz-token" type="s">
      <default>''</default>
      <summary>ListenBrainz user token (from listenbrainz.org/profile/api-keys)</summary>
    </key>

    <!-- ── Media player filter ───────────────────────────────────────────── -->
    <key name="player-blocklist" type="as">
      <default>[]</default>
      <summary>Blocked media player identities (MPRIS bus-name suffixes)</summary>
      <description>
        Comma-separated list of player identities to ignore, e.g. "firefox,chromium".
        The identity is the lowercase suffix after "org.mpris.MediaPlayer2." with
        trailing instance numbers stripped.
      </description>
    </key>

    <!-- ── Timing ────────────────────────────────────────────────────────── -->
    <key name="animation-duration" type="i">
      <default>280</default>
      <summary>Animation duration (ms)</summary>
    </key>
    <key name="osd-timeout" type="i">
      <default>2500</default>
      <summary>OSD auto-hide timeout (ms)</summary>
    </key>

    <!-- ── Appearance ────────────────────────────────────────────────────── -->
    <key name="notch-scale" type="d">
      <default>1.0</default>
      <summary>Global scale multiplier (0.5–3.0)</summary>
    </key>
    <key name="background-color" type="s">
      <default>'#0a0a0a'</default>
      <summary>Background color (HEX)</summary>
    </key>
    <key name="background-opacity" type="d">
      <default>0.84</default>
      <summary>Background opacity (0.1–1.0)</summary>
    </key>
    <key name="dynamic-art-color" type="b">
      <default>false</default>
      <summary>Use album art dominant colour as island background</summary>
    </key>

    <!-- ── State dimensions ──────────────────────────────────────────────── -->
    <key name="pill-width"      type="i"><default>160</default><summary>Idle state width (px)</summary></key>
    <key name="pill-height"     type="i"><default>34</default> <summary>Idle state height (px)</summary></key>
    <key name="compact-width"   type="i"><default>190</default><summary>Compact state width (px)</summary></key>
    <key name="compact-height"  type="i"><default>34</default> <summary>Compact state height (px)</summary></key>
    <key name="expanded-width"  type="i"><default>450</default><summary>Expanded state width (px)</summary></key>
    <key name="expanded-height" type="i"><default>140</default><summary>Expanded state height (px)</summary></key>
    <key name="osd-width"       type="i"><default>325</default><summary>OSD state width (px)</summary></key>
    <key name="osd-height"      type="i"><default>110</default><summary>OSD state height (px)</summary></key>

    <!-- ── Artwork sizes ─────────────────────────────────────────────────── -->
    <key name="art-expanded-size" type="i">
      <default>110</default>
      <summary>Album art size in expanded view (px)</summary>
    </key>
    <key name="art-compact-size" type="i">
      <default>28</default>
      <summary>Album art thumbnail size in compact view (px)</summary>
    </key>

  </schema>
</schemalist>
